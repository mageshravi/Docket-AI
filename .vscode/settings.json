{
    "workbench.colorCustomizations": {
        "activityBar.background": "#060c5d",
        "titleBar.activeBackground": "#091583",
        "titleBar.activeForeground": "#FFFBFD",
        "titleBar.inactiveBackground": "#081181",
        "titleBar.inactiveForeground": "#060B58",
        "statusBar.background": "#0A1394",
        "statusBar.foreground": "#FBFCFF",
        "statusBar.debuggingBackground": "#0A1394",
        "statusBar.debuggingForeground": "#FBFCFF",
        "statusBar.noFolderBackground": "#0A1394",
        "statusBar.noFolderForeground": "#FBFCFF"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit",
            "source.fixAll": "explicit"
        }
    },
    "[django-html]": {
        "editor.defaultFormatter": "monosans.djlint"
    },
    "editor.formatOnSave": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true
}
