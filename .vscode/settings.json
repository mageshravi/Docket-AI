{
    "workbench.colorCustomizations": {
        "activityBar.background": "#060c5d",
        "titleBar.activeBackground": "#091583",
        "titleBar.activeForeground": "#FFFBFD",
        "titleBar.inactiveBackground": "#081181",
        "titleBar.inactiveForeground": "#FAFAFF",
        "statusBar.background": "#081181",
        "statusBar.foreground": "#FAFAFF",
        "statusBar.debuggingBackground": "#081181",
        "statusBar.debuggingForeground": "#FAFAFF",
        "statusBar.noFolderBackground": "#081181",
        "statusBar.noFolderForeground": "#FAFAFF"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit",
            "source.fixAll": "explicit"
        }
    },
    "[django-html]": {
        "editor.defaultFormatter": "monosans.djlint"
    },
    "editor.formatOnSave": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "chat.tools.terminal.autoApprove": {
        "pytest": true
    }
}
